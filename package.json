{
  "name": "x-telegram-bot-channel-no-db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node --import tsx dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "grammy": "^1.42.0",
    "node-cron": "^4.2.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
