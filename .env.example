# Variables are ordered most-needed first. The two REQUIRED ones are at
# the top; everything below is OPTIONAL and ordered by how likely you
# are to need it, least-needed last.

# REQUIRED. Telegram bot token from @BotFather. The bot won't start
# without it.
BOT_TOKEN=""

# REQUIRED. The channel the bot posts to. The bot won't start without it.
#
# Accepts:
#   * Numeric id (recommended):  CHANNEL_CHAT_ID="-1001234567890"
#   * Public @-username:         CHANNEL_CHAT_ID="@mychannel"
#
# Best practice is the numeric id: it never changes, even if you later
# rename the channel's public username, so posting can never break that
# way. Do NOT put a https://t.me/... URL here; Telegram rejects a URL as
# a chat id. The bot account must be a channel admin with the "Post
# messages" permission.
CHANNEL_CHAT_ID=""

# OPTIONAL. The channel's public link, shown only in the /start reply so
# people can tap through to the channel. Kept separate from
# CHANNEL_CHAT_ID on purpose: posting uses the stable id above, this is
# just the cosmetic link. Accepts a full URL, a t.me/... value, or an
# @username. Leave empty for a private channel (no public link). If you
# set CHANNEL_CHAT_ID to an @username, the link is derived from it
# automatically and you can leave this empty.
CHANNEL_PUBLIC_URL=""

# OPTIONAL. Timezone for all cron schedules in src/schedules.ts. The
# code default is UTC, which is rarely what you want, so set this to
# your audience's zone. Examples: "Africa/Cairo", "Europe/London",
# "Asia/Riyadh".
TZ_NAME="Africa/Cairo"

# OPTIONAL. Your Telegram user ID (get it from @userinfobot). Enables
# the /admin_* commands for that one user. Leave empty to disable all
# admin commands.
ADMIN_TELEGRAM_ID=""

# OPTIONAL. Set to "production" on hosted environments (quietens debug
# logs). Anything else is treated as development.
NODE_ENV="development"

# OPTIONAL. HTTP port for the /health endpoint. Defaults to 8080. Many
# hosts inject their own PORT, so you usually leave this empty.
PORT=""
