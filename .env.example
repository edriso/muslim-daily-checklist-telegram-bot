# Telegram bot token from @BotFather.
BOT_TOKEN=""

# Your Telegram user ID (get it from @userinfobot). Used to authorise the
# /admin_* commands. Leave empty if you don't need admin commands.
ADMIN_TELEGRAM_ID=""

# REQUIRED. The channel the bot posts to. Without it the bot won't start.
#
# Accepts:
#   * @-username for public channels:   CHANNEL_CHAT_ID="@mychannel"
#   * Numeric ID for private channels:  CHANNEL_CHAT_ID="-1001234567890"
#
# The bot account must be added to the channel as an admin with the
# "Post messages" permission.
CHANNEL_CHAT_ID=""

# Timezone for all cron schedules in src/schedules.ts. Defaults to UTC if
# empty. Examples: "Africa/Cairo", "Europe/London", "Asia/Riyadh".
TZ_NAME="Africa/Cairo"

# Optional. Set to "production" on hosted environments.
NODE_ENV="development"

# Optional. HTTP port for the /health endpoint. Defaults to 8080.
PORT=""
